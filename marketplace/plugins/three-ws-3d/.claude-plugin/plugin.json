{
  "name": "three-ws-3d",
  "displayName": "three.ws 3D Forge",
  "description": "three.ws 3D Forge — generate textured 3D models and rigged, animation-ready avatars from text or images. Free text→3D (NVIDIA NIM / TRELLIS) plus the paid mesh, avatar, and auto-rig lanes, scene composition, and live avatar embeds, all wired over the three.ws MCP servers.",
  "version": "1.0.0",
  "author": {
    "name": "nirholas",
    "url": "https://three.ws"
  },
  "homepage": "https://three.ws/forge",
  "license": "Apache-2.0",
  "repository": "https://github.com/nirholas/three.ws",
  "keywords": [
    "3d",
    "forge",
    "avatar",
    "glb",
    "text-to-3d",
    "image-to-3d",
    "rigging",
    "trellis",
    "mcp"
  ],
  "mcpServers": {
    "3d-agent": {
      "command": "npx",
      "args": [
        "-y",
        "@three-ws/mcp-server"
      ],
      "env": {
        "MCP_SVM_PAYMENT_ADDRESS": "${MCP_SVM_PAYMENT_ADDRESS}"
      }
    },
    "scene": {
      "command": "npx",
      "args": [
        "-y",
        "@three-ws/scene-mcp"
      ]
    },
    "avatar": {
      "command": "npx",
      "args": [
        "-y",
        "@three-ws/avatar-mcp"
      ]
    }
  }
}
