# Keep the full test suite's source out of the deploy upload, but PRESERVE the
# critical-path gate files (scripts/test-gate.mjs runs them during the Vercel
# build and FAILS the deploy if they are stripped). Mirror the examples/ idiom
# below: exclude contents, re-include the directory, then re-include the exact
# files. This list MUST stay in sync with GATE_TESTS in scripts/test-gate.mjs —
# the gate now fails loudly naming any file missing from the build context.
tests/*
!tests/api
tests/api/*
!tests/solana-confirm.test.js
!tests/http-cache-control.test.js
!tests/agent-custody-guards.test.js
!tests/agent-wallet-vanity.test.js
!tests/api/x402.test.js
!tests/api/three-token-leaderboard.test.js
!tests/api/healthz.test.js
specs
examples/*
!examples/skills
examples/skills/*
# Keep every skill that api/_lib/skill-runtime.js can dynamically import(). The
# import paths are computed from SKILL_MAP, so Vercel's static tracer cannot see
# them; includeFiles bundles them, but ONLY if they survive this upload filter.
# pump-fun-strategy alone is not enough — it invokes pump-fun / pump-fun-trade /
# solana-wallet at runtime (strategy-backtest scan, live trades). Dropping any
# of these reintroduces "Cannot find module .../<skill>/handlers.js" 502s.
!examples/skills/pump-fun-strategy
!examples/skills/pump-fun
!examples/skills/pump-fun-trade
!examples/skills/pump-fun-compose
!examples/skills/solana-wallet
contracts
sdk
chat-plugin
cz-package
sims-demo
3d-demo

xspace-agent
agent-voice-chat
agent-protocol-sdk

animation-sources

infra
crates
experiments
scratch

dist-lib
dist-artifact

public/screenshots
public/skills.mp4

# vitest.config.js stays in the upload: scripts/test-gate.mjs needs its extended
# hookTimeouts + @grpc dedupe to run the gate tests' heavy cold imports on Vercel.
vite.config.artifact.js
playwright.config.*
scripts/gitpretty.sh

# Local prompt-pack scratch (git-ignored) — must not ship in the deploy upload;
# the build-time verify:solana scanner walks every uploaded file and reference
# snippets in here carry non-canonical constants by design.
_prompts/
