# Copy to .env and fill in.
# .env is gitignored.

# RPC endpoints
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# Deployer private key (no 0x prefix works, 0x prefix also works)
DEPLOYER_PK=

# BaseScan API key (for contract verification)
BASESCAN_API_KEY=

# ── AgentPayments deploy ────────────────────────────────────────────────────
# Owner = protocol/global buyback authority for the AgentPayments contract.
# Set to the platform multisig in production; defaults to the deployer EOA.
AGENT_PAYMENTS_OWNER=

# Per-chain RPCs for multichain AgentPayments deploys (Base uses BASE_RPC_URL above).
ETH_RPC_URL=https://eth.llamarpc.com
ARB_RPC_URL=https://arb1.arbitrum.io/rpc
POLYGON_RPC_URL=https://polygon-rpc.com
BSC_RPC_URL=https://bsc-dataseed.binance.org
AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc
