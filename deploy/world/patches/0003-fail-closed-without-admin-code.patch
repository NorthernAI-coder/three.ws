 if (!process.env.ADMIN_CODE) {
-  console.warn('[envs] ADMIN_CODE not set - all users will have admin permissions!')
+  // Fail closed in production: without ADMIN_CODE, Hyperfy's Settings.effectiveRank
+  // falls back to Ranks.ADMIN, so EVERY visitor joins with admin/build rights and
+  // can delete the ground or replace the scene. That fail-open default is how
+  // world.three.ws was repeatedly left UNPROTECTED (the 2026-06-12 void-fall).
+  // Refuse to boot so a secret-less revision fails its startup probe and Cloud Run
+  // keeps serving the last protected revision instead of exposing build rights.
+  // Exit explicitly instead of throwing: `import 'ses'` installs an uncaught-exception
+  // handler that reports the error but still lets the process exit 0, which reads as a
+  // clean shutdown in Cloud Run logs. A non-zero code names the failure for what it is.
+  if (process.env.NODE_ENV === 'production') {
+    console.error('[envs] ADMIN_CODE not set - refusing to start an UNPROTECTED world in production')
+    process.exit(1)
+  }
+  console.warn('[envs] ADMIN_CODE not set - all users will have admin permissions!')
 }
