{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "preserve",
    "allowJs": false,
    "checkJs": false,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "types": []
  },
  "include": ["src/solana/vanity/wasm/*.d.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "dist-lib",
    "dist-artifact",
    "agent-payments-sdk",
    "agent-protocol-sdk",
    "agent-voice-chat",
    "avatar-sdk",
    "character-studio",
    "chat",
    "chat-plugin",
    "examples",
    "mcp-bridge",
    "mcp-server",
    "multiplayer",
    "packages",
    "pump-fun-skills",
    "rider",
    "scripts",
    "sdk",
    "solana-agent-sdk",
    "solana-mobile",
    "tests",
    "three-ws",
    "vendor",
    "workers",
    "x402-buildout",
    "xspace-agent"
  ]
}
