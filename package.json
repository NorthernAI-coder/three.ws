{
	"private": true,
	"type": "module",
	"version": "1.5.1",
	"name": "3d-agent",
	"description": "AI-powered 3D model viewer — drag-and-drop glTF/GLB preview tool.",
	"author": "nirholas",
	"license": "Apache-2.0",
	"overrides": {
		"serialize-javascript": ">=7.0.5",
		"@esbuild-plugins/node-globals-polyfill": "^0.2.0"
	},
	"engines": {
		"node": "24.x"
	},
	"keywords": [
		"3d-viewer",
		"gltf-viewer",
		"glb-viewer",
		"3d-model-viewer",
		"webgl",
		"threejs",
		"drag-and-drop",
		"3d-agent"
	],
	"workspaces": [
		"agent-payments-sdk",
		"agent-ui-sdk",
		"avatar-sdk",
		"character-studio",
		"mcp-bridge",
		"mcp-server",
		"multiplayer",
		"packages/avatar-schema",
		"packages/avatar-cli",
		"packages/viewer-presets",
		"packages/pumpfun-mcp",
		"packages/ibm-watsonx-mcp",
		"packages/ibm-x402-mcp",
		"packages/threews-avatar-mcp"
	],
	"main": "src/app.js",
	"browserslist": [
		">1%",
		"not dead"
	],
	"staticFiles": {
		"staticPath": [
			{
				"staticPath": "assets",
				"staticOutDir": "assets"
			}
		]
	},
	"scripts": {
		"postinstall": "(node scripts/build-cache.mjs check agent-payments-sdk agent-payments-sdk/src agent-payments-sdk/package.json || (npm run build --prefix agent-payments-sdk && node scripts/build-cache.mjs stamp agent-payments-sdk agent-payments-sdk/src agent-payments-sdk/package.json)) && (node scripts/fix-pump-sdk-esm.mjs & node scripts/fix-x402-extensions-esm.mjs & node scripts/fix-colyseus-storage.mjs & node scripts/copy-three-decoders.mjs & node scripts/setup-claude-skills.mjs & wait)",
		"dev": "vite --port 3000",
		"dev:multi": "npm run dev --prefix multiplayer",
		"dev:walk-all": "node scripts/dev-walk-all.mjs",
		"dev:lib": "TARGET=lib vite",
		"presence": "node scripts/three-ws-presence.mjs",
		"build:pages": "node scripts/build-page-index.mjs",
		"audit:pages": "node scripts/audit-page-index.mjs",
		"audit:handlers": "node scripts/audit-empty-handlers.mjs",
		"audit:web": "node scripts/page-audit.mjs",
		"snapshot": "node scripts/page-snapshot.mjs",
		"build:news": "node scripts/build-news.mjs",
		"prebuild": "(node scripts/build-news.mjs & node scripts/build-skill-metadata.mjs & node scripts/build-local-skill-packs.mjs & npm run build:club-assets & wait) && (node scripts/build-page-index.mjs && node scripts/audit-page-index.mjs && node scripts/audit-empty-handlers.mjs)",
		"build": "NODE_OPTIONS='--no-deprecation --max-old-space-size=6144' vite build && node scripts/strip-sw-from-embeds.mjs",
		"build:wasm": "PATH=\"$HOME/.cargo/bin:$PATH\" RUSTFLAGS='-C target-feature=+simd128' wasm-pack build crates/vanity-grinder --target web --release --out-dir ../../src/solana/vanity/wasm && printf '%s\\n' '# wasm-pack writes a default `*` gitignore that excludes everything.' '# Override it: the generated files in this directory ARE checked in so the' '# app builds without requiring a Rust toolchain at install time. Run' '# `npm run build:wasm` after editing /crates/vanity-grinder/src/lib.rs to' '# refresh these artifacts.' '!*' > src/solana/vanity/wasm/.gitignore",
		"build:animations": "node scripts/build-animations.mjs",
		"bake:mannequin": "node scripts/bake-mannequin-glb.mjs",
		"build:club-props": "node scripts/build-club-props.mjs",
		"build:club-venue": "node scripts/build-club-venue.mjs",
		"build:club-hdri": "node scripts/build-club-hdri.mjs",
		"build:club-audio": "node scripts/build-club-audio.mjs",
		"build:club-assets": "(npm run build:club-props & npm run build:club-venue & npm run build:club-hdri & wait)",
		"build:artifact-viewer": "node scripts/build-artifact-viewer.mjs",
		"build:lib": "TARGET=lib vite build",
		"build:lib:full": "TARGET=lib LIB_FORMATS=es,umd vite build",
		"build:artifact": "vite build --config vite.config.artifact.js",
		"publish:lib": "node scripts/publish-lib.mjs",
		"build:chat": "cd chat && node scripts/ensure-deps.mjs && npm run build && cd .. && mkdir -p dist/chat && cp -rf public/chat/. dist/chat/",
		"build:avatar-studio": "npm run build --prefix character-studio",
		"build:fast": "npm run build",
		"build:vercel": "node scripts/build-vercel.mjs",
		"apply:r2-cors": "node scripts/set-r2-cors.mjs || echo '[apply:r2-cors] skipped (missing creds or transient failure — see build log)'",
		"build:all": "npm run build:chat && (npm run build & npm run build:lib & wait)",
		"release:lib": "npm run build:lib && npm run publish:lib",
		"clean": "rm -rf dist/* dist-lib/* || true",
		"generate-icons": "node scripts/generate-pwa-icons.mjs",
		"build:extension": "node scripts/build-extension-icons.mjs && node scripts/build-extension.mjs",
		"build:extension:prod": "node scripts/build-extension-icons.mjs && node scripts/build-extension.mjs --prod",
		"optimize:glb": "node scripts/optimize-glb.mjs",
		"compress:glbs": "node scripts/compress-glbs.mjs",
		"fetch-animations": "node scripts/download-animations.mjs",
		"fetch:mixamo-catalog": "node scripts/fetch-mixamo-catalog.mjs",
		"test": "vitest run && playwright test",
		"test:core": "vitest run --maxWorkers=1",
		"test:e2e": "playwright test",
		"test:pages": "node scripts/test-pages.mjs",
		"verify:ibm": "node scripts/verify-ibm-pages.mjs",
		"test:all": "npm run test && npm run test:pages",
		"verify": "prettier --check . && vite build",
		"format": "prettier --write .",
		"check:dist": "node scripts/check-dist.mjs",
		"deploy": "npm run build:all && npm run check:dist && vercel --local-config vercel.json --prod",
		"postversion": "git push && git push --tags",
		"validate:cards": "node scripts/validate-agent-cards.mjs",
		"db:migrate": "node scripts/apply-migrations.mjs --apply",
		"db:status": "node scripts/apply-migrations.mjs",
		"pump:smoke": "node scripts/pumpfun-lifecycle-smoke.js",
		"pump:refresh-idls": "node scripts/refresh-pump-idls.mjs",
		"seed:skills": "node scripts/seed-skills.js",
		"install:sdk": "npm install --prefix agent-payments-sdk && npm run build --prefix agent-payments-sdk && npm install ./agent-payments-sdk",
		"claude": "./scripts/claude.sh"
	},
	"dependencies": {
		"@0xsplits/splits-sdk": "^6.5.0",
		"@ai-sdk/anthropic": "^3.0.81",
		"@ai-sdk/openai": "^3.0.68",
		"@avaturn/sdk": "^1.1.4",
		"@aws-sdk/client-marketplace-entitlement-service": "^3.1063.0",
		"@aws-sdk/client-marketplace-metering": "^3.1063.0",
		"@aws-sdk/client-s3": "^3.1063.0",
		"@aws-sdk/s3-request-presigner": "^3.1063.0",
		"@bonfida/spl-name-service": "0.1.67",
		"@chenglou/pretext": "^0.0.7",
		"@coin-communities/sdk": "^1.2.1",
		"@coinbase/x402": "^2.1.0",
		"@coral-xyz/anchor": "^0.32.1",
		"@dimforge/rapier3d-compat": "^0.19.3",
		"@elevenlabs/elevenlabs-js": "^2.51.0",
		"@ethereum-attestation-service/eas-sdk": "^2.9.1",
		"@gltf-transform/core": "^4.4.0",
		"@gltf-transform/extensions": "^4.4.0",
		"@jup-ag/api": "^6.0.48",
		"@mediapipe/tasks-vision": "^0.10.35",
		"@metaplex-foundation/js": "^0.20.1",
		"@metaplex-foundation/mpl-agent-registry": "^0.2.5",
		"@metaplex-foundation/mpl-core": "^1.10.0",
		"@metaplex-foundation/umi": "^1.5.1",
		"@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@neondatabase/serverless": "^0.10.1",
		"@neynar/nodejs-sdk": "^3.176.0",
		"@nirholas/pump-sdk": "^1.0.0",
		"@noble/curves": "^2.2.0",
		"@node-saml/node-saml": "^5.1.0",
		"@octokit/rest": "^22.0.1",
		"@pixiv/three-vrm": "^3.5.3",
		"@privy-io/js-sdk-core": "^0.67.0",
		"@pump-fun/agent-payments-sdk": "^3.0.3",
		"@pump-fun/pump-sdk": "^1.36.0",
		"@pump-fun/pump-swap-sdk": "^1.17.0",
		"@pythnetwork/hermes-client": "^3.1.0",
		"@recast-navigation/core": "^0.43.1",
		"@recast-navigation/three": "^0.43.1",
		"@sentry/node": "^10.56.0",
		"@solana-mobile/mobile-wallet-adapter-protocol": "^2.2.9",
		"@solana-mobile/mobile-wallet-adapter-protocol-web3js": "^2.2.9",
		"@solana/actions": "^0.0.2",
		"@solana/kit": "^6.9.0",
		"@solana/pay": "^0.2.6",
		"@solana/spl-token": "^0.4.14",
		"@solana/wallet-adapter-base": "^0.9.23",
		"@solana/wallet-adapter-phantom": "^0.9.24",
		"@solana/web3.js": "^1.98.4",
		"@sparticuz/chromium-min": "^148.0.0",
		"@tetsuo-ai/protocol": "^0.2.0",
		"@tetsuo-ai/sdk": "^1.4.0",
		"@three-ws/solana-agent": "file:solana-agent-sdk",
		"@upstash/qstash": "^2.11.0",
		"@upstash/ratelimit": "^2.0.5",
		"@upstash/redis": "^1.38.0",
		"@vercel/og": "^0.11.1",
		"@walletconnect/ethereum-provider": "^2.23.9",
		"@x402/axios": "^2.14.0",
		"@x402/core": "^2.14.0",
		"@x402/evm": "^2.14.0",
		"@x402/express": "^2.14.0",
		"@x402/extensions": "^2.12.0",
		"@x402/mcp": "^2.14.0",
		"@x402/svm": "^2.14.0",
		"@zauthx402/sdk": "^0.1.14",
		"agent0-sdk": "^1.5.3",
		"ai": "^6.0.197",
		"bcryptjs": "^3.0.3",
		"bn.js": "^5.2.3",
		"bs58": "^6.0.0",
		"colyseus": "^0.17.10",
		"colyseus.js": "0.16.22",
		"dat.gui": "^0.7.9",
		"ethers": "^6.16.0",
		"express": "^5.2.1",
		"fast-check": "^4.8.0",
		"gltf-validator": "^2.0.0-dev.3.10",
		"graphql": "^16.14.1",
		"helius-sdk": "^2.2.2",
		"jose": "^5.9.6",
		"lightweight-charts": "^5.2.0",
		"livekit-client": "^2.19.2",
		"livepeer": "^3.5.0",
		"meshoptimizer": "^1.1.1",
		"nipplejs": "^1.0.4",
		"node-fetch": "^3.3.2",
		"node-html-parser": "^7.1.0",
		"postprocessing": "^6.39.1",
		"puppeteer-core": "^25.1.0",
		"qrcode": "^1.5.4",
		"query-string": "^9.4.0",
		"qwen-ai-provider": "^0.1.1",
		"resend": "^6.12.4",
		"sas-lib": "^1.0.10",
		"short-uuid": "6.0.3",
		"simple-dropzone": "^0.8.3",
		"three": "latest",
		"three-mesh-bvh": "^0.9.10",
		"three-pathfinding": "^1.3.0",
		"twitter-api-v2": "^1.29.0",
		"vhtml": "^2.2.0",
		"viem": "^2.52.2",
		"wawa-lipsync": "^0.0.2",
		"ws": "^8.21.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@gltf-transform/functions": "^4.4.0",
		"@playwright/test": "^1.60.0",
		"@x402/fetch": "^2.14.0",
		"ajv": "^8.20.0",
		"ajv-formats": "^3.0.1",
		"jsdom": "27.3.0",
		"knip": "^6.16.1",
		"playwright": "^1.45.1",
		"prettier": "^3.2.5",
		"sharp": "^0.34.5",
		"vite": "^7.3.2",
		"vite-plugin-node-polyfills": "^0.28.0",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.7",
		"workbox-build": "^7.4.0",
		"workbox-window": "^7.4.0"
	}
}
