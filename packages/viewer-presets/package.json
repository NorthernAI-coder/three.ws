	],
	"author": "three.ws <support@three.ws> (https://three.ws)",
	"license": "Apache-2.0",
	"homepage": "https://three.ws",
	"repository": {
		"type": "git",
		"url": "https://github.com/nirholas/three.ws.git",
		"directory": "packages/viewer-presets"
	},
	"type": "module",
	"main": "./src/index.js",
	"module": "./src/index.js",
	"types": "./src/index.d.ts",
	"exports": {
		".": {
