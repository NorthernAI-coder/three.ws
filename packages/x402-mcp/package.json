{
	"name": "@three-ws/x402-mcp",
	"version": "0.2.0",
	"mcpName": "io.github.nirholas/x402-mcp",
	"description": "Give any AI agent a self-custodial x402 wallet. Inspect an endpoint's price without paying, discover services on any x402 bazaar, and pay_and_call any x402 endpoint in USDC from your own Solana key — real @x402 settlement, bounded by spend caps. No custodial wallet, no account.",
	"type": "module",
	"author": "nirholas <support@three.ws>",
	"license": "Apache-2.0",
	"homepage": "https://three.ws",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nirholas/three.ws.git",
		"directory": "packages/x402-mcp"
	},
	"bugs": {
		"url": "https://github.com/nirholas/three.ws/issues"
	},
	"keywords": [
		"mcp",
		"model-context-protocol",
		"x402",
		"solana",
		"usdc",
		"payments",
		"agent-payments",
		"bazaar",
		"ai-agent"
	],
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"src",
		"server.json",
		"README.md",
		"LICENSE"
	],
	"bin": {
		"x402-mcp": "src/index.js"
	},
	"main": "./src/index.js",
	"exports": {
		".": "./src/index.js"
	},
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"start": "node src/index.js",
		"test": "node --test \"test/**/*.test.mjs\"",
		"inspect": "npx -y @modelcontextprotocol/inspector node src/index.js"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@solana/kit": "^6.9.0",
		"@solana/spl-token": "^0.4.14",
		"@solana/web3.js": "^1.98.4",
		"@x402/core": "^2.14.0",
		"@x402/fetch": "^2.14.0",
		"@x402/svm": "^2.14.0",
		"bs58": "^6.0.0",
		"zod": "^3.23.8"
	}
}
