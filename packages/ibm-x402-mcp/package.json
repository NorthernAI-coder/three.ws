{
	"name": "@three-ws/ibm-x402-mcp",
	"version": "1.1.0",
	"description": "x402 pay-per-use MCP server for IBM Granite AI — chat, code, embeddings, analysis, and time-series forecasting. Pay USDC on Solana per call. No IBM Cloud account required.",
	"type": "module",
	"author": "nirholas",
	"license": "Apache-2.0",
	"homepage": "https://github.com/nirholas/ibm-x402-mcp",
	"mcpName": "io.github.nirholas/ibm-x402-mcp",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nirholas/ibm-x402-mcp.git"
	},
	"bugs": {
		"url": "https://github.com/nirholas/ibm-x402-mcp/issues"
	},
	"keywords": [
		"mcp",
		"model-context-protocol",
		"ibm",
		"watsonx",
		"ibm-granite",
		"granite",
		"x402",
		"usdc",
		"solana",
		"pay-per-use",
		"ai-agent",
		"foundation-models",
		"embeddings",
		"time-series"
	],
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"src",
		"server.json",
		"README.md",
		"LICENSE"
	],
	"bin": {
		"ibm-x402-mcp": "src/index.js"
	},
	"main": "./src/index.js",
	"exports": {
		".": "./src/index.js"
	},
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"start": "node src/index.js",
