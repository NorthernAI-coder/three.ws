		"inspect": "npx -y @modelcontextprotocol/inspector node src/index.js"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@x402/core": "^2.13.0",
		"@x402/extensions": "^2.13.0",
		"@x402/mcp": "^2.13.0",
		"@x402/svm": "^2.13.0",
		"zod": "^3.23.8",
		"zod-to-json-schema": "3.25.2"
	}
