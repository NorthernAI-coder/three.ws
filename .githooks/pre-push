#!/bin/sh
# Pre-push safety net. GitHub Actions are unavailable on this account, so no
# CI runs tests or typecheck — the Vercel build is the only automated gate,
# and it fires after the push. This hook runs the same typecheck that gates
# deploys (npm run typecheck) before anything leaves the machine.
#
# Bypass (emergencies only): git push --no-verify   or   SKIP_HOOKS=1 git push
#
# Wired via `git config core.hooksPath .githooks` (npm run setup does this).

if [ "$SKIP_HOOKS" = "1" ]; then
	exit 0
fi

echo "[pre-push] npm run typecheck"
if ! npm run typecheck; then
	echo "" >&2
	echo "[pre-push] typecheck failed — push blocked." >&2
	echo "[pre-push] Fix the errors above, or bypass with: git push --no-verify" >&2
	exit 1
fi
