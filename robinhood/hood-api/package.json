{
  "name": "hood-api",
  "version": "0.1.0",
  "description": "Hosted market-data API for Robinhood Chain (chain ID 4663): Stock Tokens with Chainlink + DEX premium/discount, memecoin launchpads, multiplier-correct portfolios, cross-venue tokenized-equity spreads, and a real-time firehose. Free tier + x402-metered paid endpoints.",
  "keywords": [
    "robinhood",
    "robinhood-chain",
    "stock-tokens",
    "tokenized-equities",
    "market-data",
    "x402",
    "usdg",
    "hono",
    "api"
  ],
  "license": "Apache-2.0",
  "author": "nirholas (https://x.com/nichxbt)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nirholas/hood-api.git"
  },
  "homepage": "https://nirholas.github.io/hood-api/",
  "bugs": {
    "url": "https://github.com/nirholas/hood-api/issues"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "openapi": "tsx scripts/emit-openapi.ts",
    "capture-samples": "tsx scripts/capture-samples.ts",
    "smoke": "bash scripts/smoke.sh",
    "test": "vitest run",
    "test:x402": "vitest run test/x402.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/node-ws": "^1.3.1",
    "@hono/zod-openapi": "^1.4.0",
    "dotenv": "^17.4.0",
    "hono": "^4.12.0",
    "hoodchain": "file:hoodchain-0.1.0.tgz",
    "viem": "^2.55.0",
    "ws": "^8.18.0",
    "x402-hono": "^1.2.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0",
    "x402": "^1.2.0",
    "x402-fetch": "^1.2.0"
  }
}
