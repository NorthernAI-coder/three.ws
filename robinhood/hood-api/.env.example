# hood-api configuration. Copy to .env and fill in. Every var has a sane default;
# the free tier runs with NONE of these set.

# ---- Server ----
PORT=8787
# Public base URL the docs/OpenAPI advertise (no trailing slash).
PUBLIC_BASE_URL=http://localhost:8787

# ---- Upstreams (optional failover; public endpoints are the defaults) ----
# Alchemy RPC key. When set, RPC reads fail over from the public RPC to Alchemy.
ALCHEMY_KEY=
# Fully custom mainnet RPC URL (overrides the public RPC + Alchemy).
HOOD_RPC_URL=
# CoinGecko Pro/Demo API key (raises rate limits for /v1/equities). Optional.
COINGECKO_API_KEY=

# ---- x402 paid endpoints ----
# Address that receives x402 settlements. REQUIRED to enable paid endpoints;
# when unset, paid endpoints return 503 with a clear "payments not configured" hint.
X402_PAY_TO=
# Settlement network for x402: "base" (mainnet USDC) or "base-sepolia" (testnet).
X402_NETWORK=base-sepolia
# x402 facilitator URL. Testnet default is the public x402.org facilitator.
# For Base mainnet USDC settlement use the CDP facilitator (see README).
X402_FACILITATOR_URL=https://x402.org/facilitator
# CDP facilitator credentials (Base mainnet settlement only).
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
# HMAC secret used to sign metered firehose session tokens. Auto-generated per
# process if unset (fine for single-instance; set a stable value for a fleet).
FIREHOSE_SESSION_SECRET=

# ---- x402 client (E2E test only; never commit a funded key) ----
# A base-sepolia-funded key used ONLY by test/x402.test.ts to prove the
# 402 -> pay -> 200 flow. Leave empty in production.
X402_TEST_PRIVATE_KEY=
