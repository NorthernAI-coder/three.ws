# hood-mcp environment
#
# The DATA server (hood-mcp) needs NOTHING here — it runs zero-config against the
# public Robinhood Chain RPC. Everything below is optional for it, and required
# only where noted for the TRADING server (hood-mcp-trading).

# ---- shared (optional) ----
# Which network to target. 'mainnet' = chain 4663, 'testnet' = chain 46630.
HOOD_MCP_NETWORK=mainnet
# Optional Alchemy key for a faster/private RPC. Public RPC is used when unset.
# ALCHEMY_KEY=your_alchemy_key

# ---- data server: HTTP transport (optional) ----
# Set to run the data server over Streamable HTTP instead of stdio.
# HOOD_MCP_TRANSPORT=http
# HOOD_MCP_PORT=8730

# ---- trading server: REQUIRED to enable any mutating tool ----
# Master kill switch. The trading server refuses to start unless this is exactly "1".
HOOD_MCP_ENABLE_TRADING=0
# Wallet private key (0x + 64 hex). NEVER commit a real value.
# ROBINHOOD_CHAIN_PRIVATE_KEY=0x...
# Hard spend caps, denominated in USD (USDG). Per single call and per session.
HOOD_MCP_MAX_SPEND_USDG=25
HOOD_MCP_MAX_SESSION_USDG=100
# Set to "1" ONLY if you are eligible to acquire tokenized Stock Tokens
# (NOT a US/CA/UK/CH person). Required for swaps whose OUTPUT is a Stock Token.
HOOD_MCP_ACKNOWLEDGE_ELIGIBILITY=0

# ---- x402 monetization seam (optional, off by default) ----
# When the sibling `hood402` package is installed AND this is set, the HTTP
# transport paywalls the tools listed in PAID_TOOLS. Free tools stay free.
# HOOD_MCP_PAYWALL_PRICE=0.005
# HOOD_MCP_PAY_TO=0xYourSettlementWallet
