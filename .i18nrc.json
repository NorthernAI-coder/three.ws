{
  "$schema": "./scripts/i18n-rc.schema.json",
  "entry": "locales/en.json",
  "entryLocale": "en",
  "output": "locales",
  "outputLocales": [
    "es",
    "zh-CN",
    "ja",
    "ko",
    "fr",
    "de",
    "pt-BR",
    "ar",
    "hi",
    "ru"
  ],
  "localeNames": {
    "en": "English",
    "es": "Español",
    "zh-CN": "简体中文",
    "ja": "日本語",
    "ko": "한국어",
    "fr": "Français",
    "de": "Deutsch",
    "pt-BR": "Português (BR)",
    "ar": "العربية",
    "hi": "हिन्दी",
    "ru": "Русский"
  },
  "rtlLocales": ["ar", "he", "fa", "ur"],
  "provider": "gemini",
  "modelName": "gemini-2.5-flash",
  "temperature": 0.2,
  "topP": 0.9,
  "concurrency": 4,
  "splitToken": 1200,
  "saveImmediately": true,
  "reference": "three.ws is a platform to build, animate, rig, and monetize 3D AI agents on-chain. The audience is crypto-native developers and creators. Keep copy punchy and product-grade — match the energy of Vercel, Linear, and Stripe marketing. Prefer the natural, idiomatic phrasing a native speaker in that market would use over a literal word-for-word rendering. Preserve the marketing voice; do not pad or soften.",
  "htmlExtract": {
    "entry": [
      "pages/**/*.html",
      "public/**/*.html"
    ],
    "exclude": [
      "**/node_modules/**",
      "public/chat/**",
      "src/scene-studio/vendor/**"
    ]
  },
  "doNotTranslate": [
    "$THREE",
    "FeMbDoX7R1Psc4GEcvJdsbNbZA3bfztcyDCatJVJpump",
    "three.ws",
    "x402",
    "USDC",
    "Solana",
    "IBM watsonx.ai",
    "watsonx.ai",
    "Granite",
    "ERC-8004",
    "MCP",
    "pump.fun",
    "GLB",
    "glTF",
    "WebGL",
    "Three.js",
    "Forge"
  ]
}
